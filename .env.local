# Configuration pour développement local (debug mode)

# --- Server Configuration ---
TRANSPORT=http
MCP_HOST=localhost
MCP_PORT=8000
MCP_API_PATH=/mcp
MCP_SERVER_SECRET_KEY=

# --- API Configuration ---
OPENAPI_URL=https://api.data.inclusion.beta.gouv.fr/api/openapi.json
MCP_SERVER_NAME=DataInclusionAPI
# Remplacez par votre vraie clé API (laissez vide pour les tests)
DATA_INCLUSION_API_KEY=
GEMINI_API_KEY=
LOGFIRE_TOKEN=
AGENT_MCP_CONNECTION_MAX_RETRIES=15
AGENT_MCP_CONNECTION_BASE_DELAY=0.5
AGENT_MCP_CONNECTION_BACKOFF_MULTIPLIER=1.5
AGENT_MODEL_NAME=gpt-4.1

# --- Redis Configuration (localhost pour développement) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- URLs pour développement local ---
MCP_SERVER_URL=http://localhost:8000/mcp
AGENT_SERVER_PORT=8001 